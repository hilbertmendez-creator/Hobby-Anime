# Identidad y rutas del NAS
PUID=1000
PGID=1000
TZ=America/Mexico_City
DATA_ROOT=/volume1/data
QBITTORRENT_CONFIG_ROOT=/volume1/docker/hobby-anime/qbittorrent
JELLYFIN_CONFIG_ROOT=/volume1/docker/hobby-anime/jellyfin/config
JELLYFIN_CACHE_ROOT=/volume1/docker/hobby-anime/jellyfin/cache
AGENT_CONFIG_ROOT=/volume1/docker/hobby-anime/agent
OLLAMA_CONFIG_ROOT=/volume1/docker/hobby-anime/ollama

# Puertos publicados en la red local
QBITTORRENT_WEB_PORT=8080
QBITTORRENT_PEER_PORT=6881
JELLYFIN_WEB_PORT=8096

# Usa únicamente feeds y contenido que tengas derecho a descargar
RSS_URLS=https://example.org/authorized-media-feed.xml
RSS_RESOLUTION=1080p
RSS_GROUPS=
RSS_INCLUDE_TERMS=
RSS_EXCLUDE_TERMS=cam,ts
RSS_MAX_AGE_HOURS=72

# Política obligatoria de idioma español
SPANISH_ONLY=true
SPANISH_LANGUAGE_TERMS=spanish,español,castellano,latino,latam,sub esp,subesp,spa
SPANISH_NEGATIVE_TERMS=raw,english only,no subs,sin subtítulos
SPANISH_TRUSTED_GROUPS=
SPANISH_SUBTITLE_EXCLUDE_TERMS=forced,signs,songs,carteles,canciones

# Credenciales configuradas en Web UI > Tools > Options > Web UI
QBITTORRENT_HOST=qbittorrent
QBITTORRENT_PORT=8080
QBITTORRENT_USERNAME=admin
QBITTORRENT_PASSWORD=change-me
QBITTORRENT_SAVE_PATH=/data/torrents/quarantine
QBITTORRENT_CATEGORY=hobby-anime
QBITTORRENT_VERIFIED_PATH=/data/torrents/verified
QBITTORRENT_VERIFIED_CATEGORY=hobby-anime-verified
QBITTORRENT_REJECTED_CATEGORY=hobby-anime-rejected

# Ejecución automática
DAILY_HOUR=3
DAILY_MINUTE=0
VERIFICATION_INTERVAL_MINUTES=10
MONTHLY_DAY=1
MONTHLY_HOUR=9
DATABASE_PATH=/config/hobby-anime.db
MEDIA_PATH=/data/media
LOG_LEVEL=INFO
REQUEST_TIMEOUT_SECONDS=30
FFPROBE_PATH=ffprobe
FFPROBE_TIMEOUT_SECONDS=60

# Descubrimiento con AniList y un LLM local opcional
ANILIST_URL=https://graphql.anilist.co
OLLAMA_ENABLED=false
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:3b

# Configura uno o ambos canales; vacíos significa que el reporte queda en logs
WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Direcciones internas para las comprobaciones de salud
JELLYFIN_URL=http://jellyfin:8096
